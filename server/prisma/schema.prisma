generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// SysWise token cache — no local User table
model Session {
  userId       Int      @id
  syswiseToken String
  updatedAt    DateTime @updatedAt
}

model Settings {
  id                      String   @id @default(uuid())
  userId                  Int      @unique
  notifications           Boolean  @default(true)
  measurementUnit         String   @default("metric")
  weightUnit              String   @default("kg")
  measurementReminderDays Int      @default(14)
  height                  Float?   // cm — used for BMI calculation
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ─── EXERCISE LIBRARY ────────────────────────────────────────────────────────

model Exercise {
  id               String   @id @default(uuid())
  name             String
  category         String
  primaryMuscle    String
  secondaryMuscles String[]
  bodyPartFocus    String
  equipment        String
  trackingType     String
  demoVideoUrl     String?
  sourceUrl        String?
  instructions     String?
  safetyNotes      String?
  isSystem         Boolean  @default(false)
  createdByUserId  Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workoutPlanExercises WorkoutPlanExercise[]
  workoutExerciseLogs  WorkoutExerciseLog[]
}

// ─── WORKOUT PLANS ────────────────────────────────────────────────────────────

model WorkoutPlan {
  id         String   @id @default(uuid())
  userId     Int
  name       String
  date       String?
  isTemplate Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  exercises WorkoutPlanExercise[]
  sessions  WorkoutSession[]
}

model WorkoutPlanExercise {
  id             String      @id @default(uuid())
  workoutPlanId  String
  workoutPlan    WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exerciseId     String
  exercise       Exercise    @relation(fields: [exerciseId], references: [id])
  orderIndex     Int         @default(0)
  targetSets     Int?
  targetReps     Int?
  targetWeight   Float?
  targetTimeSeconds Int?
  restSeconds    Int?
  notes          String?
}

// ─── WORKOUT SESSIONS ─────────────────────────────────────────────────────────

model WorkoutSession {
  id            String       @id @default(uuid())
  userId        Int
  workoutPlanId String?
  workoutPlan   WorkoutPlan? @relation(fields: [workoutPlanId], references: [id])
  date          String
  startedAt     DateTime     @default(now())
  endedAt       DateTime?
  status        String       @default("planned")
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  exerciseLogs WorkoutExerciseLog[]
}

model WorkoutExerciseLog {
  id               String         @id @default(uuid())
  workoutSessionId String
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exerciseId       String
  exercise         Exercise       @relation(fields: [exerciseId], references: [id])
  orderIndex       Int            @default(0)
  completed        Boolean        @default(false)
  actualTimeSeconds Int?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  sets WorkoutSetLog[]
}

model WorkoutSetLog {
  id                   String             @id @default(uuid())
  workoutExerciseLogId String
  workoutExerciseLog   WorkoutExerciseLog @relation(fields: [workoutExerciseLogId], references: [id], onDelete: Cascade)
  setNumber            Int
  weight               Float?
  reps                 Int?
  timeSeconds          Int?
  completed            Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

// ─── MEALS ────────────────────────────────────────────────────────────────────

model MealLog {
  id        String   @id @default(uuid())
  userId    Int
  date      String
  time      String?
  mealType  String
  foodItems String
  calories  Float?
  protein   Float?
  carbs     Float?
  fat       Float?
  waterMl   Float?
  notes     String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── FASTING ─────────────────────────────────────────────────────────────────

model FastingSession {
  id          String    @id @default(uuid())
  userId      Int
  startTime   DateTime
  endTime     DateTime?
  targetHours Float     @default(16)
  status      String    @default("active")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── HABITS / STREAKS ─────────────────────────────────────────────────────────

model Habit {
  id            String   @id @default(uuid())
  userId        Int
  name          String
  description   String?
  frequency     String   @default("daily")
  selectedDays  Int[]
  targetValue   Float?
  unit          String?
  startDate     String
  reminderTime  String?
  motivationMsg String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  completions HabitCompletion[]
}

model HabitCompletion {
  id        String   @id @default(uuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId    Int
  date      String
  completed Boolean  @default(false)
  value     Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([habitId, date])
}

// ─── HEALTH MEASUREMENTS ─────────────────────────────────────────────────────

model HealthMeasurement {
  id                String   @id @default(uuid())
  userId            Int
  date              String
  weight            Float?
  waist             Float?
  chest             Float?
  hip               Float?
  neck              Float?
  leftArm           Float?
  rightArm          Float?
  leftThigh         Float?
  rightThigh        Float?
  bodyFatPercentage Float?
  bmi               Float?
  restingHeartRate  Int?
  systolicBp        Int?
  diastolicBp       Int?
  spo2              Float?
  bodyTemperature   Float?
  fastingGlucose    Float?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
